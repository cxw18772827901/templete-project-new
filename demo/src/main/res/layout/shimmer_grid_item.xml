    <com.skydoves.androidveil.VeilLayout
        android:id="@+id/sl1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="561:729"
        app:layout_constraintEnd_toStartOf="@id/sl2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:veilLayout_baseAlpha="1.0"
        app:veilLayout_baseColor="@color/cl_aaa"
        app:veilLayout_defaultChildVisible="true"
        app:veilLayout_dropOff="0.5"
        app:veilLayout_highlightAlpha="1.0"
        app:veilLayout_highlightColor="@color/cl_eee"
        app:veilLayout_radius="0dp"
        app:veilLayout_shimmerEnable="true"
        app:veilLayout_veiled="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>
    </com.skydoves.androidveil.VeilLayout>

    <com.skydoves.androidveil.VeilLayout
        android:id="@+id/sl2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/x1"
        app:layout_constraintDimensionRatio="561:729"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/sl1"
        app:layout_constraintTop_toTopOf="parent"
        app:veilLayout_baseAlpha="1.0"
        app:veilLayout_baseColor="@color/cl_aaa"
        app:veilLayout_defaultChildVisible="true"
        app:veilLayout_dropOff="0.5"
        app:veilLayout_highlightAlpha="1.0"
        app:veilLayout_highlightColor="@color/cl_eee"
        app:veilLayout_radius="0dp"
        app:veilLayout_shimmerEnable="true"
        app:veilLayout_veiled="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>
    </com.skydoves.androidveil.VeilLayout>

