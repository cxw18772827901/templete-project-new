    <com.skydoves.androidveil.VeilLayout
        android:id="@+id/sl2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/x32"
        android:layout_marginHorizontal="@dimen/x10"
        android:layout_marginVertical="@dimen/x10"
        app:layout_constraintBottom_toTopOf="@id/view1"
        app:layout_constraintDimensionRatio="375:211"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sl1"
        app:veilLayout_baseAlpha="1.0"
        app:veilLayout_baseColor="@color/cl_aaa"
        app:veilLayout_defaultChildVisible="true"
        app:veilLayout_dropOff="0.5"
        app:veilLayout_highlightAlpha="1.0"
        app:veilLayout_highlightColor="@color/cl_eee"
        app:veilLayout_radius="0dp"
        app:veilLayout_shimmerEnable="true"
        app:veilLayout_veiled="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>
    </com.skydoves.androidveil.VeilLayout>

    <View
        android:id="@+id/view1"
        android:layout_width="@dimen/x24"
        android:layout_height="@dimen/x24"
        android:layout_marginStart="@dimen/x10"
        android:layout_marginBottom="@dimen/x24"
        android:background="@drawable/small_val"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sl2" />

    <com.skydoves.androidveil.VeilLayout
        android:id="@+id/sl3"
        android:layout_width="0dp"
        android:layout_height="@dimen/x13"
        android:layout_marginStart="@dimen/x5"
        app:layout_constraintBottom_toBottomOf="@id/view1"
        app:layout_constraintStart_toEndOf="@id/view1"
        app:layout_constraintTop_toTopOf="@id/view1"
        app:layout_constraintWidth_percent="0.704"
        app:veilLayout_baseAlpha="1.0"
        app:veilLayout_baseColor="@color/cl_aaa"
        app:veilLayout_defaultChildVisible="true"
        app:veilLayout_dropOff="0.5"
        app:veilLayout_highlightAlpha="1.0"
        app:veilLayout_highlightColor="@color/cl_eee"
        app:veilLayout_radius="0dp"
        app:veilLayout_shimmerEnable="true"
