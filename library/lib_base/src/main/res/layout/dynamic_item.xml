<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="boo"
            type="Boolean" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@{boo?@color/app_color_white:@color/app_color_red}">

        <!--android:maxLines="1"-->
        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/tv"
            android:layout_width="match_parent"
            android:layout_height="@dimen/x150"
            android:layout_marginHorizontal="@dimen/x60"
            android:layout_marginVertical="@dimen/x30"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/white"
            android:textSize="@dimen/x45"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shape_radius="@dimen/x80"
            app:shape_solidColor="@color/cl_1692DB"
            tools:ignore="HardcodedText" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>